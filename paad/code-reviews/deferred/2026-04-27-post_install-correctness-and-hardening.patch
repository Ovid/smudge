+    Returns (loaded_dict, status) where status is one of:
+      "loaded"    — file existed and parsed; loaded_dict has its content
+      "absent"    — file does not exist; loaded_dict is {}
+      "backed_up" — file existed but was corrupt; moved to .bak;
+                    loaded_dict is {}
+      "failed"    — file existed but couldn't be loaded AND couldn't be
+                    backed up; the original is intact, callers MUST NOT
